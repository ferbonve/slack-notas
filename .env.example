# Plantilla de variables de entorno (SIN secretos: este archivo SÍ se commitea).
# En local: copialo a .env y completá los valores reales (.env está gitignoreado).
# En la nube (claude.ai/code): cargá estas mismas claves como Environment
# variables / Secrets del proyecto. NO subas los valores reales al repo.

# --- Slack ---
# Bot User OAuth Token (empieza con xoxb-). https://api.slack.com/apps
SLACK_TOKEN=
# ID del canal de notas (ej: C0123ABCDEF).
CHANNEL_ID=

# --- Google Drive (OAuth de usuario con refresh token) ---
# Se generan con: python autorizar_drive.py
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ID de la carpeta de Drive donde vive el CSV (y, dentro, la subcarpeta de notas).
DRIVE_FOLDER_ID=
# Nombre del CSV en Drive.
DRIVE_CSV_NOMBRE=notas_slack.csv
# (Opcional) nombre de la subcarpeta de notas dentro de DRIVE_FOLDER_ID.
NOTAS_CARPETA_DRIVE=notas
